# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL=sqlite:///./cyberrisk.db
# For PostgreSQL: postgresql://user:password@localhost:5432/cyberrisk

# ── MQTT Broker ───────────────────────────────────────────────────────────────
MQTT_BROKER_HOST=localhost
MQTT_BROKER_PORT=1883

# ── Ollama LLM (your Victus HP at 192.168.1.4) ───────────────────────────────
OLLAMA_BASE_URL=http://192.168.1.4:11434
OLLAMA_MODEL=qwen3:4b

# ── ML ────────────────────────────────────────────────────────────────────────
ANOMALY_THRESHOLD=0.65

# ── CORS (frontend URL) ───────────────────────────────────────────────────────
# CORS_ORIGINS=["http://localhost:5173"]

# ── Debug ─────────────────────────────────────────────────────────────────────
DEBUG=False
